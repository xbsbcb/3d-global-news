# GlobeNews 环境变量配置示例
# 复制为 .env 后修改值

# ===================
# 后端配置
# ===================

# 数据库路径
DATABASE_URL=sqlite:./data/globe_news.db

# WorldNews API Key (从 https://worldnewsapi.com/ 获取)
WORLDNEWS_API_KEY=your_api_key_here

# 服务器端口
PORT=8080

# 日志级别
RUST_LOG=info

# ===================
# 前端配置
# ===================

# API 地址 (前端开发时使用)
VITE_API_BASE_URL=http://localhost:8080
